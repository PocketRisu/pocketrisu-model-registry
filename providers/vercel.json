{
  "id": "vercel",
  "name": "Vercel AI Gateway",
  "version": 1,
  "description": "Vercel's AI Gateway (OpenAI-compatible endpoint at /v1/chat/completions). Use 'vendor/model' model IDs. Vercel also exposes Anthropic-format (/v1/messages) and Google-format endpoints — use a separate Anthropic / Google template pointed at the Vercel host for those formats.",
  "messageFormat": "openai",

  "auth": { "type": "bearer", "fieldKey": "api-key" },

  "schema": {
    "type": "object",
    "properties": {
      "api-key": {
        "type": "array",
        "items": { "type": "string" },
        "title": "API Key",
        "description": "Vercel AI Gateway key. Multiple keys rotate automatically."
      },
      "model": {
        "type": "string",
        "title": "Model",
        "description": "Vendor-prefixed model ID in 'creator/model-name' form. See https://vercel.com/ai-gateway/models for the live list.",
        "examples": [
          "anthropic/claude-opus-4.7",
          "anthropic/claude-sonnet-4.7",
          "openai/gpt-5.5",
          "openai/gpt-5.5-pro",
          "google/gemini-3.5-flash",
          "deepseek/deepseek-v4-pro",
          "deepseek/deepseek-v4-flash"
        ]
      },
      "custom-params": {
        "type": "string",
        "title": "Custom Params (JSON)",
        "description": "Free-form JSON merged into the request body.",
        "default": ""
      },
      "pricing-input": {
        "type": "number",
        "title": "Pricing — Input ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "pricing-output": {
        "type": "number",
        "title": "Pricing — Output ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "pricing-cache-read": {
        "type": "number",
        "title": "Pricing — Cache Read ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "pricing-cache-write": {
        "type": "number",
        "title": "Pricing — Cache Write ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "default": 1.0,
        "minimum": 0,
        "maximum": 2
      }
    },
    "required": ["api-key", "model"]
  },

  "uiSchema": {
    "api-key": { "ui:widget": "secret-list" },
    "model": { "ui:widget": "combobox" },
    "custom-params": { "ui:widget": "textarea", "ui:options": { "rows": 3, "collapsed": true } },
    "pricing-input": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "pricing-output": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "pricing-cache-read": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "pricing-cache-write": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "temperature": { "ui:widget": "slider", "ui:options": { "step": 0.1 } }
  },

  "models": [],

  "request": {
    "url": "https://ai-gateway.vercel.sh/v1/chat/completions",
    "method": "POST",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "model": "{{model}}",
      "messages": "{{$messages}}",
      "max_tokens": "{{$max_tokens}}",
      "stream": "{{$streaming}}",
      "temperature": "{{temperature}}"
    }
  },

  "response": {
    "streaming": {
      "format": "sse",
      "style": "openai",
      "textPath": "choices[0].delta.content",
      "doneSentinel": "[DONE]",
      "usagePath": "usage"
    },
    "nonStreaming": {
      "textPath": "choices[0].message.content",
      "usagePath": "usage"
    }
  }
}
