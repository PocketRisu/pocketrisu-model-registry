{
  "id": "deepseek",
  "name": "DeepSeek",
  "version": 1,
  "description": "DeepSeek Chat / Reasoner / V4 (api.deepseek.com, OpenAI-compatible). Uses /beta/chat/completions to expose the V4 family (deepseek-v4-pro / deepseek-v4-flash) and beta features like prefix completion. /v1/chat/completions still works for older models but doesn't carry V4.",
  "messageFormat": "openai",

  "auth": { "type": "bearer", "fieldKey": "api-key" },

  "schema": {
    "type": "object",
    "properties": {
      "api-key": {
        "type": "array",
        "items": { "type": "string" },
        "title": "API Key",
        "description": "DeepSeek API key. Multiple keys rotate automatically."
      },
      "model": {
        "type": "string",
        "title": "Model",
        "default": "deepseek-v4-pro",
        "examples": ["deepseek-v4-pro", "deepseek-v4-flash", "deepseek-chat", "deepseek-reasoner"]
      },
      "reasoning": {
        "type": "string",
        "title": "Reasoning Level",
        "enum": ["off", "high", "max"],
        "default": "off",
        "description": "Only effective on deepseek-reasoner."
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "default": 1.0,
        "minimum": 0,
        "maximum": 2
      }
    },
    "required": ["api-key", "model"]
  },

  "uiSchema": {
    "api-key": { "ui:widget": "secret-list" },
    "model": { "ui:widget": "combobox" },
    "reasoning": { "ui:widget": "select" },
    "temperature": { "ui:widget": "slider", "ui:options": { "step": 0.1 } }
  },

  "models": [
    { "id": "deepseek-v4-pro", "name": "DeepSeek V4 Pro", "capabilities": ["streaming", "thinking", "prefill", "tools"] },
    { "id": "deepseek-v4-flash", "name": "DeepSeek V4 Flash", "capabilities": ["streaming", "thinking", "prefill", "tools"] },
    { "id": "deepseek-chat", "name": "DeepSeek Chat", "capabilities": ["streaming", "tools"] },
    { "id": "deepseek-reasoner", "name": "DeepSeek Reasoner", "capabilities": ["streaming", "thinking"] }
  ],

  "request": {
    "url": "https://api.deepseek.com/beta/chat/completions",
    "method": "POST",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "model": "{{model}}",
      "messages": "{{$messages}}",
      "max_tokens": "{{$max_tokens}}",
      "stream": "{{$streaming}}",
      "temperature": "{{temperature}}"
    }
  },

  "conditionals": [
    {
      "if": { "model": "deepseek-reasoner" },
      "remove": { "body": ["temperature", "top_p", "frequency_penalty", "presence_penalty"] }
    },
    {
      "if": { "reasoning": "high" },
      "merge": { "body": { "reasoning_effort": "high" } }
    },
    {
      "if": { "reasoning": "max" },
      "merge": { "body": { "reasoning_effort": "max" } }
    }
  ],

  "response": {
    "streaming": {
      "format": "sse",
      "style": "openai",
      "textPath": "choices[0].delta.content",
      "thinkingPath": "choices[0].delta.reasoning_content",
      "doneSentinel": "[DONE]",
      "usagePath": "usage"
    },
    "nonStreaming": {
      "textPath": "choices[0].message.content",
      "thinkingPath": "choices[0].message.reasoning_content",
      "usagePath": "usage"
    }
  }
}
