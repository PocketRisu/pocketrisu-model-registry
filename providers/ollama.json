{
  "id": "ollama",
  "name": "Ollama (Self-hosted)",
  "version": 1,
  "description": "Self-hosted Ollama server. Point at your localhost or LAN endpoint. For Ollama's hosted cloud at ollama.com, use the separate 'ollama-cloud' template instead.",
  "messageFormat": "openai",

  "auth": { "type": "bearer", "fieldKey": "api-key" },

  "schema": {
    "type": "object",
    "properties": {
      "base-url": {
        "type": "string",
        "title": "Base URL",
        "description": "Your Ollama server URL (must include the protocol).",
        "default": "http://localhost:11434",
        "examples": [
          "http://localhost:11434",
          "http://127.0.0.1:11434",
          "http://192.168.1.10:11434"
        ]
      },
      "api-key": {
        "type": "array",
        "items": { "type": "string" },
        "title": "API Key (optional)",
        "description": "Only needed if you put a reverse proxy with auth in front of Ollama. If empty, PocketRisu omits the Authorization header entirely so vanilla Ollama works out of the box."
      },
      "model": {
        "type": "string",
        "title": "Model",
        "description": "Pulled model name. Run 'ollama list' to see what's available.",
        "examples": [
          "llama3.3",
          "qwen3:32b",
          "deepseek-r1:70b",
          "gemma3:27b"
        ]
      },
      "custom-params": {
        "type": "string",
        "title": "Custom Params (JSON)",
        "description": "Free-form JSON merged into the request body.",
        "default": ""
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "default": 0.7,
        "minimum": 0,
        "maximum": 2
      }
    },
    "required": ["base-url", "model"]
  },

  "uiSchema": {
    "base-url": { "ui:widget": "text" },
    "api-key": { "ui:widget": "secret-list", "ui:options": { "collapsed": true } },
    "model": { "ui:widget": "combobox" },
    "custom-params": { "ui:widget": "textarea", "ui:options": { "rows": 3, "collapsed": true } },
    "temperature": { "ui:widget": "slider", "ui:options": { "step": 0.1 } }
  },

  "models": [],

  "request": {
    "url": "{{base-url}}/v1/chat/completions",
    "method": "POST",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "model": "{{model}}",
      "messages": "{{$messages}}",
      "max_tokens": "{{$max_tokens}}",
      "stream": "{{$streaming}}",
      "temperature": "{{temperature}}"
    }
  },

  "response": {
    "streaming": {
      "format": "sse",
      "style": "openai",
      "textPath": "choices[0].delta.content",
      "doneSentinel": "[DONE]",
      "usagePath": "usage"
    },
    "nonStreaming": {
      "textPath": "choices[0].message.content",
      "usagePath": "usage"
    }
  }
}
