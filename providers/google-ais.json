{
  "id": "google-ais",
  "name": "Google AI Studio (Gemini)",
  "version": 1,
  "description": "Gemini models via Google AI Studio (generativelanguage.googleapis.com).",
  "messageFormat": "google",

  "auth": { "type": "query", "fieldKey": "api-key", "param": "key" },

  "schema": {
    "type": "object",
    "properties": {
      "api-key": {
        "type": "array",
        "items": { "type": "string" },
        "title": "API Key",
        "description": "Google AI Studio API key. Multiple keys rotate automatically."
      },
      "model": {
        "type": "string",
        "title": "Model",
        "examples": [
          "gemini-3-pro",
          "gemini-3-flash",
          "gemini-2.5-pro",
          "gemini-2.5-flash"
        ]
      },
      "thinking": {
        "type": "string",
        "title": "Thinking Mode",
        "enum": ["off", "level", "budget"],
        "default": "off",
        "description": "Level = Gemini 3 semantic levels. Budget = Gemini 2.5 token budget."
      },
      "thinking-level": {
        "type": "string",
        "title": "Thinking Level",
        "enum": ["MINIMAL", "LOW", "MEDIUM", "HIGH"],
        "default": "MEDIUM"
      },
      "thinking-budget": {
        "type": "integer",
        "title": "Thinking Budget (tokens)",
        "default": 8000,
        "minimum": 0,
        "maximum": 32768
      },
      "preserve-system": {
        "type": "boolean",
        "title": "Preserve System Instruction",
        "default": true,
        "description": "Keep the system prompt in systemInstruction (instead of merging into contents)."
      },
      "include-thoughts": {
        "type": "boolean",
        "title": "Include Thoughts in Response",
        "default": false
      },
      "use-thought-signature": {
        "type": "boolean",
        "title": "Use Thought Signature",
        "default": false,
        "description": "Required for some Gemini 3 multi-turn thinking flows."
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "default": 1.0,
        "minimum": 0,
        "maximum": 2
      }
    },
    "required": ["api-key", "model"]
  },

  "uiSchema": {
    "api-key": { "ui:widget": "secret-list" },
    "model": { "ui:widget": "combobox" },
    "thinking": { "ui:widget": "select" },
    "thinking-level": {
      "ui:widget": "select",
      "ui:options": { "showIf": { "thinking": "level" } }
    },
    "thinking-budget": {
      "ui:widget": "number",
      "ui:options": { "showIf": { "thinking": "budget" } }
    },
    "preserve-system": { "ui:widget": "toggle" },
    "include-thoughts": { "ui:widget": "toggle" },
    "use-thought-signature": { "ui:widget": "toggle", "ui:options": { "collapsed": true } },
    "temperature": { "ui:widget": "slider", "ui:options": { "step": 0.1 } }
  },

  "models": [
    { "id": "gemini-3-pro", "name": "Gemini 3 Pro", "capabilities": ["streaming", "thinking", "vision", "tools"] },
    { "id": "gemini-3-flash", "name": "Gemini 3 Flash", "capabilities": ["streaming", "thinking", "vision", "tools"] },
    { "id": "gemini-2.5-pro", "name": "Gemini 2.5 Pro", "capabilities": ["streaming", "thinking", "vision", "tools"] },
    { "id": "gemini-2.5-flash", "name": "Gemini 2.5 Flash", "capabilities": ["streaming", "thinking", "vision", "tools"] }
  ],

  "request": {
    "url": "https://generativelanguage.googleapis.com/v1beta/models/{{model}}:streamGenerateContent?alt=sse",
    "method": "POST",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "contents": "{{$messages}}",
      "systemInstruction": "{{$system}}",
      "generationConfig": {
        "maxOutputTokens": "{{$max_tokens}}",
        "temperature": "{{temperature}}"
      }
    }
  },

  "conditionals": [
    {
      "if": { "thinking": "level" },
      "merge": {
        "body": {
          "generationConfig": {
            "thinkingConfig": {
              "thinkingLevel": "{{thinking-level}}",
              "includeThoughts": "{{include-thoughts}}"
            }
          }
        }
      }
    },
    {
      "if": { "thinking": "budget" },
      "merge": {
        "body": {
          "generationConfig": {
            "thinkingConfig": {
              "thinkingBudget": "{{thinking-budget}}",
              "includeThoughts": "{{include-thoughts}}"
            }
          }
        }
      }
    }
  ],

  "response": {
    "streaming": {
      "format": "sse",
      "style": "google",
      "textPath": "candidates[0].content.parts[0].text",
      "thinkingPath": "candidates[0].content.parts[0].thought",
      "doneSentinel": null,
      "usagePath": "usageMetadata"
    },
    "nonStreaming": {
      "textPath": "candidates[0].content.parts[0].text",
      "usagePath": "usageMetadata"
    }
  }
}
