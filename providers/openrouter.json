{
  "id": "openrouter",
  "name": "OpenRouter",
  "version": 1,
  "description": "Multi-vendor router. Use 'vendor/model-id' format (e.g. 'anthropic/claude-sonnet-4.7').",
  "messageFormat": "openai",

  "auth": { "type": "bearer", "fieldKey": "api-key" },

  "schema": {
    "type": "object",
    "properties": {
      "api-key": {
        "type": "array",
        "items": { "type": "string" },
        "title": "API Key",
        "description": "OpenRouter API key. Multiple keys rotate automatically."
      },
      "model": {
        "type": "string",
        "title": "Model",
        "description": "OpenRouter model ID in 'vendor/model' form. See https://openrouter.ai/models",
        "examples": [
          "anthropic/claude-sonnet-4.7",
          "anthropic/claude-opus-4.7",
          "openai/gpt-5.5",
          "openai/gpt-5",
          "google/gemini-3-pro",
          "deepseek/deepseek-chat",
          "meta-llama/llama-4-405b-instruct"
        ]
      },
      "provider-order": {
        "type": "string",
        "title": "Provider Routing",
        "description": "Comma-separated provider preference (e.g. 'Hyperbolic,Together'). PocketRisu's OpenRouter dispatch splits this into an array for body.provider.order. Leave empty for OpenRouter default."
      },
      "reasoning-effort": {
        "type": "string",
        "title": "Reasoning Effort",
        "description": "OpenRouter normalizes effort across upstream vendors. 'none' disables; 'xhigh' is the strongest.",
        "enum": ["none", "minimal", "low", "medium", "high", "xhigh"],
        "default": "none"
      },
      "custom-params": {
        "type": "string",
        "title": "Custom Params (JSON)",
        "description": "Free-form JSON merged into the request body.",
        "default": ""
      },
      "pricing-input": {
        "type": "number",
        "title": "Pricing — Input ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "pricing-output": {
        "type": "number",
        "title": "Pricing — Output ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "pricing-cache-read": {
        "type": "number",
        "title": "Pricing — Cache Read ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "pricing-cache-write": {
        "type": "number",
        "title": "Pricing — Cache Write ($/1M tokens)",
        "default": 0,
        "minimum": 0
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "default": 1.0,
        "minimum": 0,
        "maximum": 2
      }
    },
    "required": ["api-key", "model"]
  },

  "uiSchema": {
    "api-key": { "ui:widget": "secret-list" },
    "model": { "ui:widget": "combobox" },
    "provider-order": { "ui:widget": "text", "ui:options": { "placeholder": "e.g. Hyperbolic,Together" } },
    "reasoning-effort": { "ui:widget": "select" },
    "custom-params": { "ui:widget": "textarea", "ui:options": { "rows": 3, "collapsed": true } },
    "pricing-input": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "pricing-output": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "pricing-cache-read": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "pricing-cache-write": { "ui:widget": "number", "ui:options": { "collapsed": true } },
    "temperature": { "ui:widget": "slider", "ui:options": { "step": 0.1 } }
  },

  "models": [
    { "id": "anthropic/claude-sonnet-4.7", "name": "Claude Sonnet 4.7 (OpenRouter)", "capabilities": ["streaming", "thinking", "vision", "cache"] },
    { "id": "anthropic/claude-opus-4.7", "name": "Claude Opus 4.7 (OpenRouter)", "capabilities": ["streaming", "thinking", "vision", "cache"] },
    { "id": "openai/gpt-5.5", "name": "GPT-5.5 (OpenRouter)", "capabilities": ["streaming", "thinking", "vision"] },
    { "id": "openai/gpt-5", "name": "GPT-5 (OpenRouter)", "capabilities": ["streaming", "thinking", "vision"] },
    { "id": "google/gemini-3-pro", "name": "Gemini 3 Pro (OpenRouter)", "capabilities": ["streaming", "thinking", "vision"] },
    { "id": "deepseek/deepseek-chat", "name": "DeepSeek Chat (OpenRouter)", "capabilities": ["streaming"] }
  ],

  "request": {
    "url": "https://openrouter.ai/api/v1/chat/completions",
    "method": "POST",
    "headers": {
      "content-type": "application/json",
      "HTTP-Referer": "https://github.com/PocketRisu/PocketRisu",
      "X-Title": "PocketRisu"
    },
    "body": {
      "model": "{{model}}",
      "messages": "{{$messages}}",
      "max_tokens": "{{$max_tokens}}",
      "stream": "{{$streaming}}",
      "temperature": "{{temperature}}"
    }
  },

  "conditionals": [
    {
      "if": { "reasoning-effort": "!none" },
      "merge": { "body": { "reasoning": { "effort": "{{reasoning-effort}}" } } }
    },
    {
      "if": { "provider-order": true },
      "merge": { "body": { "provider": { "order": "{{provider-order}}" } } }
    }
  ],

  "response": {
    "streaming": {
      "format": "sse",
      "style": "openai",
      "textPath": "choices[0].delta.content",
      "thinkingPath": "choices[0].delta.reasoning",
      "doneSentinel": "[DONE]",
      "usagePath": "usage"
    },
    "nonStreaming": {
      "textPath": "choices[0].message.content",
      "thinkingPath": "choices[0].message.reasoning",
      "usagePath": "usage"
    }
  }
}
