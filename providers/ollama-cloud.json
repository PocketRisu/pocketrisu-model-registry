{
  "id": "ollama-cloud",
  "name": "Ollama Cloud",
  "version": 1,
  "description": "Ollama's hosted cloud (ollama.com), separate from self-hosted Ollama. Requires an API key from your Ollama account. Speaks the OpenAI-compatible /v1/chat/completions endpoint.",
  "messageFormat": "openai",

  "auth": { "type": "bearer", "fieldKey": "api-key" },

  "schema": {
    "type": "object",
    "properties": {
      "api-key": {
        "type": "array",
        "items": { "type": "string" },
        "title": "API Key",
        "description": "Ollama Cloud API key (from ollama.com account settings). Multiple keys rotate automatically."
      },
      "model": {
        "type": "string",
        "title": "Model",
        "description": "Ollama Cloud model name. See ollama.com for the live list.",
        "examples": [
          "gpt-oss:120b",
          "deepseek-v3.1:671b",
          "qwen3-coder:480b",
          "llama4-maverick:128"
        ]
      },
      "custom-params": {
        "type": "string",
        "title": "Custom Params (JSON)",
        "description": "Free-form JSON merged into the request body.",
        "default": ""
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "default": 0.7,
        "minimum": 0,
        "maximum": 2
      }
    },
    "required": ["api-key", "model"]
  },

  "uiSchema": {
    "api-key": { "ui:widget": "secret-list" },
    "model": { "ui:widget": "combobox" },
    "custom-params": { "ui:widget": "textarea", "ui:options": { "rows": 3, "collapsed": true } },
    "temperature": { "ui:widget": "slider", "ui:options": { "step": 0.1 } }
  },

  "models": [],

  "request": {
    "url": "https://ollama.com/v1/chat/completions",
    "method": "POST",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "model": "{{model}}",
      "messages": "{{$messages}}",
      "max_tokens": "{{$max_tokens}}",
      "stream": "{{$streaming}}",
      "temperature": "{{temperature}}"
    }
  },

  "response": {
    "streaming": {
      "format": "sse",
      "style": "openai",
      "textPath": "choices[0].delta.content",
      "doneSentinel": "[DONE]",
      "usagePath": "usage"
    },
    "nonStreaming": {
      "textPath": "choices[0].message.content",
      "usagePath": "usage"
    }
  }
}
