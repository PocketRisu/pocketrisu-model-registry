{
  "id": "vertex",
  "name": "Vertex AI (Gemini)",
  "version": 1,
  "description": "Gemini models on Google Cloud Vertex AI. Authenticates via Service Account JSON. For Claude on Vertex Model Garden, use the separate 'vertex-claude' template (different URL path and body shape).",
  "messageFormat": "google",

  "auth": { "type": "google-service-account", "fieldKey": "service-account" },

  "schema": {
    "type": "object",
    "properties": {
      "service-account": {
        "type": "array",
        "items": { "type": "string" },
        "title": "Service Account JSON",
        "description": "Paste the full Service Account JSON. Multiple credentials rotate automatically with per-credential token caching."
      },
      "project": {
        "type": "string",
        "title": "Project ID"
      },
      "region": {
        "type": "string",
        "title": "Region",
        "default": "us-central1",
        "description": "Regional endpoint (e.g. us-central1) is the common case. Vertex also has a 'global' endpoint at aiplatform.googleapis.com (no region prefix); for that case PocketRisu's dispatch swaps the host accordingly.",
        "examples": [
          "us-central1",
          "us-east5",
          "us-west1",
          "europe-west1",
          "europe-west4",
          "asia-northeast1",
          "asia-southeast1",
          "global"
        ]
      },
      "model": {
        "type": "string",
        "title": "Model",
        "examples": [
          "gemini-3-pro",
          "gemini-3-flash",
          "gemini-2.5-pro",
          "gemini-2.5-flash"
        ]
      },
      "thinking": {
        "type": "string",
        "title": "Thinking Mode",
        "enum": ["off", "level", "budget"],
        "default": "off"
      },
      "thinking-level": {
        "type": "string",
        "title": "Thinking Level",
        "enum": ["MINIMAL", "LOW", "MEDIUM", "HIGH"],
        "default": "MEDIUM"
      },
      "thinking-budget": {
        "type": "integer",
        "title": "Thinking Budget (tokens)",
        "default": 8000,
        "minimum": 0,
        "maximum": 32768
      },
      "preserve-system": {
        "type": "boolean",
        "title": "Preserve System Instruction",
        "default": true
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "default": 1.0,
        "minimum": 0,
        "maximum": 2
      }
    },
    "required": ["service-account", "project", "model"]
  },

  "uiSchema": {
    "service-account": {
      "ui:widget": "secret-list",
      "ui:options": { "rows": 6, "placeholder": "Paste Service Account JSON here. For rotation, paste multiple (one per line)." }
    },
    "project": { "ui:widget": "text" },
    "region": { "ui:widget": "combobox" },
    "model": { "ui:widget": "combobox" },
    "thinking": { "ui:widget": "select" },
    "thinking-level": {
      "ui:widget": "select",
      "ui:options": { "showIf": { "thinking": "level" } }
    },
    "thinking-budget": {
      "ui:widget": "number",
      "ui:options": { "showIf": { "thinking": "budget" } }
    },
    "preserve-system": { "ui:widget": "toggle", "ui:options": { "collapsed": true } },
    "temperature": { "ui:widget": "slider", "ui:options": { "step": 0.1 } }
  },

  "models": [
    { "id": "gemini-3-pro", "name": "Gemini 3 Pro (Vertex)", "capabilities": ["streaming", "thinking", "vision", "tools"] },
    { "id": "gemini-3-flash", "name": "Gemini 3 Flash (Vertex)", "capabilities": ["streaming", "thinking", "vision", "tools"] },
    { "id": "gemini-2.5-pro", "name": "Gemini 2.5 Pro (Vertex)", "capabilities": ["streaming", "thinking", "vision", "tools"] },
    { "id": "gemini-2.5-flash", "name": "Gemini 2.5 Flash (Vertex)", "capabilities": ["streaming", "thinking", "vision", "tools"] }
  ],

  "request": {
    "url": "https://{{region}}-aiplatform.googleapis.com/v1/projects/{{project}}/locations/{{region}}/publishers/google/models/{{model}}:streamGenerateContent?alt=sse",
    "method": "POST",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "contents": "{{$messages}}",
      "systemInstruction": "{{$system}}",
      "generationConfig": {
        "maxOutputTokens": "{{$max_tokens}}",
        "temperature": "{{temperature}}"
      }
    }
  },

  "conditionals": [
    {
      "if": { "thinking": "level" },
      "merge": {
        "body": {
          "generationConfig": {
            "thinkingConfig": { "thinkingLevel": "{{thinking-level}}", "includeThoughts": true }
          }
        }
      }
    },
    {
      "if": { "thinking": "budget" },
      "merge": {
        "body": {
          "generationConfig": {
            "thinkingConfig": { "thinkingBudget": "{{thinking-budget}}", "includeThoughts": true }
          }
        }
      }
    }
  ],

  "response": {
    "streaming": {
      "format": "sse",
      "style": "google",
      "textPath": "candidates[0].content.parts[0].text",
      "thinkingPath": "candidates[0].content.parts[0].thought",
      "doneSentinel": null,
      "usagePath": "usageMetadata"
    },
    "nonStreaming": {
      "textPath": "candidates[0].content.parts[0].text",
      "usagePath": "usageMetadata"
    }
  }
}
