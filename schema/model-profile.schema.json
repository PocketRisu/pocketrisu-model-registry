{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pocketrisu.dev/registry/schema/model-profile.schema.json",
  "title": "ModelProfile",
  "type": "object",
  "required": [
    "id",
    "version",
    "displayName",
    "providerBaseId",
    "profileTier",
    "modelId",
    "endpoint",
    "auth",
    "defaults",
    "schema",
    "uiSchema",
    "sourceUrls"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*:[a-z][a-z0-9-]*$"
    },
    "version": { "type": "integer", "minimum": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "displayNameI18n": { "$ref": "#/$defs/i18nStringMap" },
    "providerBaseId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "profileTier": { "const": "standard" },
    "description": { "type": "string" },
    "descriptionI18n": { "$ref": "#/$defs/i18nStringMap" },
    "visibility": { "enum": ["popular", "standard", "advanced", "legacy"] },
    "lifecycle": { "enum": ["recommended", "current", "legacy", "deprecated", "experimental"] },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sortOrder": { "type": "integer" },
    "modelId": { "type": "string" },
    "endpoint": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["static", "vertex-openai"] },
        "url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["none", "bearer", "x-api-key", "x-goog-api-key", "query", "google-service-account"]
        },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "defaults": { "type": "object" },
    "schema": {
      "type": "array",
      "items": { "$ref": "base-provider.schema.json#/$defs/fieldSchema" }
    },
    "uiSchema": {
      "$ref": "base-provider.schema.json#/$defs/uiSchema"
    },
    "bodyTemplate": { "type": "object" },
    "headerTemplate": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "capabilities": {
      "type": "array",
      "items": { "enum": ["streaming", "vision", "tools", "json", "reasoning"] }
    },
    "recommendedTokenizer": {
      "enum": ["tik", "mistral", "novelai", "claude", "llama", "llama3", "novellist", "gemma", "cohere", "deepseek"],
      "description": "Default tokenizer suggestion for this profile. Used as fallback when the user has not overridden ModelPreset.tokenizerOverride."
    },
    "limits": {
      "$ref": "base-provider.schema.json#/$defs/modelLimits"
    },
    "sourceUrls": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "i18nStringMap": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}
